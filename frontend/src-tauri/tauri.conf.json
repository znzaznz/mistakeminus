{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "中级会计考试刷题器",
  "version": "0.1.0",
  "identifier": "com.mistakegenie.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "中级会计考试刷题器",
        "width": 1000,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": ["../../desktop/start-backend.ps1"]
  },
  "plugins": {}
}
